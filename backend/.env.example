PORT=3001
FRONTEND_URL=http://localhost:3000

# Postgres (self-hosted — Supabase OSS, plain Postgres, or any Postgres-compatible)
# If using Supabase locally: postgres://postgres:postgres@127.0.0.1:54322/postgres
DATABASE_URL=postgres://user:password@localhost:5432/emilie

# JWT secret — generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret

# Infomaniak Swiss Object Storage (S3-compatible)
# Endpoint: https://s3.ir-1.infomaniak.com (Infomaniak region ir-1, Switzerland)
# Create a bucket and API key at manager.infomaniak.com → Cloud → Object Storage
R2_ENDPOINT_URL=https://s3.ir-1.infomaniak.com
R2_ACCESS_KEY_ID=your-infomaniak-access-key
R2_SECRET_ACCESS_KEY=your-infomaniak-secret-key
R2_BUCKET_NAME=emilie

GEMINI_API_KEY=your-gemini-key
ANTHROPIC_API_KEY=your-anthropic-key
OPENROUTER_API_KEY=your-openrouter-key
RESEND_API_KEY=your-resend-key

# Sovereign model endpoint (any chat-completions-compatible server — no OpenAI dependency)
#
# Option A — Self-hosted (fully on-prem, zero cloud):
#   Run Apertus via vLLM: https://github.com/swiss-ai/apertus
#   VLLM_BASE_URL=http://localhost:8000/v1
#   VLLM_MAIN_MODEL=<apertus-model-id>
#
# Option B — Infomaniak AI Tools (Swiss data center, managed, includes Apertus):
#   Get API key at manager.infomaniak.com → AI Tools
#   VLLM_BASE_URL=https://api.infomaniak.com/2/ai/<product_id>/openai/v1
#   VLLM_MAIN_MODEL=apertus   (or llama3, mixtral, etc.)
#
# Select "Local Model" in the chat UI once VLLM_BASE_URL is set.
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_API_KEY=
VLLM_MAIN_MODEL=localllm-main
VLLM_LIGHT_MODEL=localllm-light

# MCP servers (JSON array) — exposes external MCP tools (e.g. Lexplorer case law) to the LLM.
# Each entry: { "name": "lexplorer", "url": "https://mcp.lexplorer.ch/sse", "apiKey": "YOUR_KEY" }
MCP_SERVERS=[]
