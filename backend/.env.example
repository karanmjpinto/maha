PORT=3001
FRONTEND_URL=http://localhost:3000

# Postgres (self-hosted — plain Postgres or any Postgres-compatible)
DATABASE_URL=postgres://user:password@localhost:5432/emilie

# JWT secret — generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret

# Object storage (S3-compatible)
# Recommended: Infomaniak Object Storage (Swiss data centers)
# Create a bucket and API key at manager.infomaniak.com → Cloud → Object Storage
# Endpoint for Infomaniak: https://s3.ir-1.infomaniak.com
# Leave blank to use local filesystem storage (backend/uploads/) — suitable for local dev
STORAGE_ENDPOINT_URL=https://s3.ir-1.infomaniak.com
STORAGE_ACCESS_KEY_ID=your-access-key
STORAGE_SECRET_ACCESS_KEY=your-secret-key
STORAGE_BUCKET_NAME=emilie

# AI model keys — cloud fallbacks, not required for sovereign deployment
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Sovereign model endpoint (any chat-completions-compatible server — no OpenAI dependency)
#
# Option A — Self-hosted (fully on-prem, zero cloud):
#   Run Apertus via vLLM: https://github.com/swiss-ai/apertus
#   VLLM_BASE_URL=http://localhost:8000/v1
#   VLLM_MAIN_MODEL=<apertus-model-id>
#
# Option B — Infomaniak AI Tools (Swiss data center, managed, includes Apertus):
#   Get API key at manager.infomaniak.com → AI Tools
#   VLLM_BASE_URL=https://api.infomaniak.com/2/ai/<product_id>/openai/v1
#   VLLM_MAIN_MODEL=apertus   (or llama3, mixtral, etc.)
#
# Select "Local Model" in the chat UI once VLLM_BASE_URL is set.
VLLM_BASE_URL=
VLLM_API_KEY=
VLLM_MAIN_MODEL=
VLLM_LIGHT_MODEL=

# MCP servers (JSON array) — connect any MCP server, tools appear in every conversation.
# transport: "http" (default, Streamable HTTP) or "sse" (legacy)
# apiKey: omit for servers that require no authentication
#
# Free Swiss legal data sources:
#   {"name":"entscheidsuche","url":"https://mcp.entscheidsuche.ch/mcp"}
#   {"name":"opencaselaw","url":"https://mcp.opencaselaw.ch/mcp"}
#   {"name":"fedlex","url":"https://fedlex-connector.ch/mcp"}
MCP_SERVERS=[]
