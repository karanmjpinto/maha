PORT=3001
FRONTEND_URL=http://localhost:3000

# Postgres (self-hosted — plain Postgres or any Postgres-compatible)
DATABASE_URL=postgres://user:password@localhost:5432/maha

# JWT secret — generate with: openssl rand -base64 48
JWT_SECRET=change-me-to-a-long-random-secret

# Object storage (S3-compatible)
# Recommended for Qatar-resident data: MEEZA Object Storage or Ooredoo Cloud (Tier IV, Qatar)
# Leave blank to use local filesystem storage (backend/uploads/) — suitable for local dev
STORAGE_ENDPOINT_URL=
STORAGE_ACCESS_KEY_ID=
STORAGE_SECRET_ACCESS_KEY=
STORAGE_BUCKET_NAME=maha

# AI model keys — cloud fallbacks, not required for sovereign Qatar deployment
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Sovereign model endpoint (any chat-completions-compatible server — no OpenAI dependency)
#
# Option A — Self-hosted (fully on-prem, zero cloud):
#   Run Fanar via vLLM: https://fanar.qa
#   VLLM_BASE_URL=http://localhost:8000/v1
#   VLLM_MAIN_MODEL=fanar
#
# Option B — QCRI managed Fanar API (hosted in Qatar):
#   Get an API key from QCRI / HBKU
#   VLLM_BASE_URL=https://api.fanar.qa/v1
#   VLLM_API_KEY=<qcri-api-key>
#   VLLM_MAIN_MODEL=fanar
#
# Select "Local Model" in the chat UI once VLLM_BASE_URL is set.
VLLM_BASE_URL=
VLLM_API_KEY=
VLLM_MAIN_MODEL=
VLLM_LIGHT_MODEL=

# MCP servers (JSON array) — connect any MCP server, tools appear in every conversation.
# transport: "http" (default, Streamable HTTP) or "sse" (legacy)
# apiKey: omit for servers that require no authentication
#
# Qatar legal data sources (MCP wrappers in backend/mcp-servers/):
#   {"name":"al-meezan","url":"http://localhost:7010/mcp"}        — Al Meezan portal: laws, decrees
#   {"name":"qfc-court","url":"http://localhost:7011/mcp"}        — QFC Court & QICDRC judgments
#   {"name":"qatar-gazette","url":"http://localhost:7012/mcp"}    — Qatar Official Gazette
#   {"name":"adaalaty","url":"http://localhost:7013/mcp"}         — Ministry of Justice services
MCP_SERVERS=[]
